[Unit]
Description=EVConcierge Django app (Gunicorn)
After=network.target

[Service]
Type=simple
User=riccardo
Group=riccardo
WorkingDirectory=/home/riccardo/Scrivania/EVConciergeWorkspace/EVConcierge
Environment="PATH=/home/riccardo/Scrivania/EVConciergeWorkspace/EVConcierge/.venv/bin"
ExecStart=/home/riccardo/Scrivania/EVConciergeWorkspace/EVConcierge/.venv/bin/gunicorn \
    --workers 3 \
    --bind 127.0.0.1:8000 \
    --access-logfile - \
    --error-logfile - \
    EVConcierge.wsgi:application
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
